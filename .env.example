# ─────────────────────────────────────────────────────────────────────────────
# Distributed High-Throughput API Rate Limiter — Environment Config
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ──────────────────────────────────────────────────────────────────
PORT=3000

# ── UPGRADE 1: Redis Connection ──────────────────────────────────────────────
# For local dev (single node):
REDIS_URL=redis://localhost:6379

# For production Redis Cluster — comma-separated host:port pairs:
# REDIS_CLUSTER_NODES=redis-0:7001,redis-1:7002,redis-2:7003

# Redis password (leave blank if ALLOW_EMPTY_PASSWORD=yes in dev)
# REDIS_PASSWORD=your-redis-password

# Set to "true" to enable TLS on the Redis connection (production)
# REDIS_TLS=false

# ── Rate Limit Defaults ──────────────────────────────────────────────────────
RATE_LIMIT_MAX=100
WINDOW_MS=60000

# ── Fail-Open Behaviour ──────────────────────────────────────────────────────
# true  = if Redis is unreachable, allow all requests through (recommended)
# false = if Redis is unreachable, return 503
FAIL_OPEN=true

# ── UPGRADE 2: TLS ───────────────────────────────────────────────────────────
# Path to TLS cert/key for app-level TLS (optional — prefer nginx termination)
# TLS_CERT_PATH=/etc/ssl/certs/server.crt
# TLS_KEsY_PATH=/etc/ssl/private/server.key

# ── UPGRADE 4: Grafana Alerting Secrets ──────────────────────────────────────
GRAFANA_PASSWORD=admin
# PagerDuty integration key (from Service → Integrations → Add Grafana)
PAGERDUTY_INTEGRATION_KEY=your-pagerduty-key-here
# Slack incoming webhook URL (from api.slack.com/apps → Incoming Webhooks)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# ── UPGRADE 5: Key Sanitization ──────────────────────────────────────────────
# Maximum allowed Redis key length in characters (default: 256)
# RATE_LIMIT_KEY_MAX_LENGTH=256
