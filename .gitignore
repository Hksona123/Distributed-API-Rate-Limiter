# ─────────────────────────────────────────────────────────────────────────────
# Node.js
# ─────────────────────────────────────────────────────────────────────────────
node_modules/
dist/
build/
*.js.map
*.d.ts

# ─────────────────────────────────────────────────────────────────────────────
# Environment — NEVER commit real secrets
# ─────────────────────────────────────────────────────────────────────────────
.env
.env.local
.env.production
.env.staging

# ─────────────────────────────────────────────────────────────────────────────
# TLS Certificates — contain private keys, never commit
# ─────────────────────────────────────────────────────────────────────────────
nginx/certs/server.key
nginx/certs/server.crt
*.pem
*.key
*.crt
*.p12

# ─────────────────────────────────────────────────────────────────────────────
# Logs
# ─────────────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*

# ─────────────────────────────────────────────────────────────────────────────
