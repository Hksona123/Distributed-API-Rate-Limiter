{
  "title": "API Rate Limiter Performance",
  "timezone": "browser",
  "schemaVersion": 36,
  "refresh": "5s",
  "panels": [
    {
      "title": "Throughput (RPS)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        { "expr": "rate(rate_limit_allowed_total[1m])", "legendFormat": "Allowed" },
        { "expr": "rate(rate_limit_rejected_total[1m])", "legendFormat": "Rejected" }
      ]
    },
    {
      "title": "Redis Lua Latency (P99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "histogram_quantile(0.99, rate(redis_latency_seconds_bucket[1m]))", "legendFormat": "P99 Latency" }
      ]
    }
  ]
}
